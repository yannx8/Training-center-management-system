```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.css.map

# Logs and temporary files
*.log
*.tmp

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
.venv/
.env

# Coverage reports
coverage/
htmlcov/
.coverage

# OS generated files
.DS_Store
Thumbs.db

# Compressed files
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.rar
*.7z

# Testing
.pytest_cache/
.mypy_cache/
.nyc_output/
coverage/

# Distribution / packaging
.pybuild/
.tox/
.coverage
.cache
nosetests.xml
```